{
  "entities": {
    "user_profile": {
      "title": "User Profile",
      "description": "Stores user-specific information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique Firebase Auth ID." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "description": "The user's profile photo URL." },
        "lastLogin": { "type": "string", "format": "date-time", "description": "The last time the user logged in." }
      },
      "required": ["uid", "email"]
    },
    "order": {
      "title": "Order",
      "description": "Stores order details submitted through the app.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "companyId": { "type": "string" },
        "contactId": { "type": "string" },
        "formData": { "type": "object" },
        "lineItems": { "type": "array" },
        "totalAmount": { "type": "number" },
        "hubspotDealId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "companyId", "formData", "lineItems", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "user_profile",
      "description": "User profile documents indexed by their Firebase Auth UID."
    },
    "/orders/{orderId}": {
      "schema": "order",
      "description": "Order documents."
    },
    "/config/hubspot": {
      "schema": "object",
      "description": "Stores the HubSpot Access Token securely."
    }
  }
}
